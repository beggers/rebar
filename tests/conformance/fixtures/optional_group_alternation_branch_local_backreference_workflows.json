  "cases": [
    {
      "id": "optional-group-alternation-branch-local-numbered-backreference-compile-metadata-str",
      "operation": "compile",
      "family": "optional_group_alternation_branch_local_numbered_backreference_compile_metadata",
      "pattern": "a((b|c)\\2)?d",
      "categories": ["grouped", "optional-group", "alternation", "numbered-backreference", "branch-local", "compile", "metadata", "str", "gap"],
      "notes": [
        "Publishes the bounded numbered compile frontier for one optional outer group whose alternation branch must still satisfy a same-branch backreference before the literal suffix."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-numbered-backreference-module-search-b-branch-str",
      "operation": "module_call",
      "family": "optional_group_alternation_branch_local_numbered_backreference_module_b_branch_workflow",
      "helper": "search",
      "args": ["a((b|c)\\2)?d", "zzabbdzz"],
      "categories": ["grouped", "optional-group", "alternation", "numbered-backreference", "branch-local", "search", "module", "present", "b-branch", "str", "gap"],
      "notes": [
        "Documents the module-level numbered optional-group branch-local search path when the optional group is present and the alternation selects the b branch."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-numbered-backreference-pattern-fullmatch-c-branch-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_numbered_backreference_pattern_c_branch_workflow",
      "pattern": "a((b|c)\\2)?d",
      "helper": "fullmatch",
      "args": ["accd"],
      "categories": ["grouped", "optional-group", "alternation", "numbered-backreference", "branch-local", "fullmatch", "pattern", "present", "c-branch", "str", "gap"],
      "notes": [
        "Documents the bound Pattern.fullmatch numbered path when the optional group is present and the alternation selects the c branch."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-numbered-backreference-pattern-fullmatch-absent-group-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_numbered_backreference_pattern_absent_group_workflow",
      "pattern": "a((b|c)\\2)?d",
      "helper": "fullmatch",
      "args": ["ad"],
      "categories": ["grouped", "optional-group", "alternation", "numbered-backreference", "branch-local", "fullmatch", "pattern", "absent", "str", "gap"],
      "notes": [
        "Documents the numbered absent-group success path so the published frontier records that the entire optional group may be omitted."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-numbered-backreference-pattern-fullmatch-no-match-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_numbered_backreference_pattern_no_match_workflow",
      "pattern": "a((b|c)\\2)?d",
      "helper": "fullmatch",
      "args": ["abd"],
      "categories": ["grouped", "optional-group", "alternation", "numbered-backreference", "branch-local", "fullmatch", "pattern", "no-match", "str", "gap"],
      "notes": [
        "Documents the numbered no-match path so the scorecard shows that a present optional group still must satisfy the later same-branch backreference."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-named-backreference-compile-metadata-str",
      "operation": "compile",
      "family": "optional_group_alternation_branch_local_named_backreference_compile_metadata",
      "pattern": "a(?P<outer>(?P<inner>b|c)(?P=inner))?d",
      "categories": ["grouped", "optional-group", "alternation", "named-group", "named-backreference", "branch-local", "compile", "metadata", "str", "gap"],
      "notes": [
        "Publishes the matching named compile frontier where an optional outer group contains one named inner alternation branch followed by a named same-branch backreference."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-named-backreference-module-search-c-branch-str",
      "operation": "module_call",
      "family": "optional_group_alternation_branch_local_named_backreference_module_c_branch_workflow",
      "helper": "search",
      "args": ["a(?P<outer>(?P<inner>b|c)(?P=inner))?d", "zzaccdzz"],
      "categories": ["grouped", "optional-group", "alternation", "named-group", "named-backreference", "branch-local", "search", "module", "present", "c-branch", "str", "gap"],
      "notes": [
        "Documents the module-level named optional-group branch-local search path when the optional group is present and the alternation selects the c branch."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-named-backreference-pattern-fullmatch-b-branch-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_named_backreference_pattern_b_branch_workflow",
      "pattern": "a(?P<outer>(?P<inner>b|c)(?P=inner))?d",
      "helper": "fullmatch",
      "args": ["abbd"],
      "categories": ["grouped", "optional-group", "alternation", "named-group", "named-backreference", "branch-local", "fullmatch", "pattern", "present", "b-branch", "str", "gap"],
      "notes": [
        "Documents the bound Pattern.fullmatch named path when the optional group is present and the alternation selects the b branch."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-named-backreference-pattern-fullmatch-absent-group-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_named_backreference_pattern_absent_group_workflow",
      "pattern": "a(?P<outer>(?P<inner>b|c)(?P=inner))?d",
      "helper": "fullmatch",
      "args": ["ad"],
      "categories": ["grouped", "optional-group", "alternation", "named-group", "named-backreference", "branch-local", "fullmatch", "pattern", "absent", "str", "gap"],
      "notes": [
        "Documents the named absent-group success path so the published frontier records that the entire optional named group may be omitted."
      ]
    },
    {
      "id": "optional-group-alternation-branch-local-named-backreference-pattern-fullmatch-no-match-str",
      "operation": "pattern_call",
      "family": "optional_group_alternation_branch_local_named_backreference_pattern_no_match_workflow",
      "pattern": "a(?P<outer>(?P<inner>b|c)(?P=inner))?d",
      "helper": "fullmatch",
      "args": ["abd"],
      "categories": ["grouped", "optional-group", "alternation", "named-group", "named-backreference", "branch-local", "fullmatch", "pattern", "no-match", "str", "gap"],
      "notes": [
        "Documents the named no-match path so the scorecard shows that a present optional group still must satisfy the later named same-branch backreference."
      ]
