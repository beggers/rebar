{
  "schema_version": 1,
  "manifest_id": "optional-group-alternation-branch-local-backreference-workflows",
  "layer": "match_behavior",
  "suite_id": "match.optional_group_alternation_branch_local_backreference",
  "defaults": {
    "text_model": "str"
