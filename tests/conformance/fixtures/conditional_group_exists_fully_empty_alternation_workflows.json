{
  "schema_version": 1,
  "manifest_id": "conditional-group-exists-fully-empty-alternation-workflows",
  "layer": "match_behavior",
  "suite_id": "match.conditional_group_exists_fully_empty_alternation",
  "defaults": {
    "text_model": "str"
  },
  "cases": [
    {
      "id": "conditional-group-exists-fully-empty-alternation-compile-metadata-str",
      "operation": "compile",
      "family": "conditional_group_exists_fully_empty_alternation_compile_metadata",
      "pattern": "a(b)?c(?(1)|(?:|))",
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "compile", "metadata", "str", "gap"],
      "notes": [
        "Publishes one bounded numbered group-exists conditional compile path whose else arm contains an explicit zero-width alternation site so the accepted `|(?:|)` spelling stays distinct from the earlier fully empty and empty-yes-arm slices."
      ]
    },
    {
      "id": "conditional-group-exists-fully-empty-alternation-module-search-present-str",
      "operation": "module_call",
      "family": "conditional_group_exists_fully_empty_alternation_module_present_workflow",
      "helper": "search",
      "args": ["a(b)?c(?(1)|(?:|))", "zzabczz"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "search", "module", "present", "str", "gap"],
      "notes": [
        "Documents the numbered module-level search path when the optional capture is present so the scorecard records the zero-width yes-arm success while keeping the explicit zero-width else-arm alternation spelling visible."
      ]
    },
    {
      "id": "conditional-group-exists-fully-empty-alternation-module-fullmatch-absent-str",
      "operation": "module_call",
      "family": "conditional_group_exists_fully_empty_alternation_module_absent_workflow",
      "helper": "fullmatch",
      "args": ["a(b)?c(?(1)|(?:|))", "ac"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "fullmatch", "module", "absent", "str", "gap"],
      "notes": [
        "Documents the numbered module-level fullmatch path when the optional capture is omitted so the explicit zero-width alternation site in the else arm contributes no suffix and the absent capture remains visible."
      ]
    },
    {
      "id": "conditional-group-exists-fully-empty-alternation-pattern-fullmatch-extra-suffix-failure-str",
      "operation": "pattern_call",
      "family": "conditional_group_exists_fully_empty_alternation_pattern_extra_suffix_failure_workflow",
      "pattern": "a(b)?c(?(1)|(?:|))",
      "helper": "fullmatch",
      "args": ["ace"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "fullmatch", "pattern", "absent", "failure", "str", "gap"],
      "notes": [
        "Documents the bound Pattern.fullmatch numbered failure path when the optional capture is absent so the scorecard proves this slice does not silently broaden into the earlier empty-yes-arm alternation spelling."
      ]
    },
    {
      "id": "named-conditional-group-exists-fully-empty-alternation-compile-metadata-str",
      "operation": "compile",
      "family": "named_conditional_group_exists_fully_empty_alternation_compile_metadata",
      "pattern": "a(?P<word>b)?c(?(word)|(?:|))",
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "named-group", "compile", "metadata", "str", "gap"],
      "notes": [
        "Publishes the matching named fully-empty conditional compile frontier for the same bounded explicit zero-width else-arm alternation shape."
      ]
    },
    {
      "id": "named-conditional-group-exists-fully-empty-alternation-module-search-present-str",
      "operation": "module_call",
      "family": "named_conditional_group_exists_fully_empty_alternation_module_present_workflow",
      "helper": "search",
      "args": ["a(?P<word>b)?c(?(word)|(?:|))", "zzabczz"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "named-group", "search", "module", "present", "str", "gap"],
      "notes": [
        "Documents the named module-level search path when the optional named capture is present so the accepted zero-width yes arm remains explicit for the alternation-bearing fully-empty spelling."
      ]
    },
    {
      "id": "named-conditional-group-exists-fully-empty-alternation-module-fullmatch-absent-str",
      "operation": "module_call",
      "family": "named_conditional_group_exists_fully_empty_alternation_module_absent_workflow",
      "helper": "fullmatch",
      "args": ["a(?P<word>b)?c(?(word)|(?:|))", "ac"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "named-group", "fullmatch", "module", "absent", "str", "gap"],
      "notes": [
        "Documents the named module-level fullmatch path when the optional named capture is absent so the explicit zero-width alternation site contributes no suffix and the named-group None payload stays explicit."
      ]
    },
    {
      "id": "named-conditional-group-exists-fully-empty-alternation-pattern-fullmatch-extra-suffix-failure-str",
      "operation": "pattern_call",
      "family": "named_conditional_group_exists_fully_empty_alternation_pattern_extra_suffix_failure_workflow",
      "pattern": "a(?P<word>b)?c(?(word)|(?:|))",
      "helper": "fullmatch",
      "args": ["acf"],
      "categories": ["grouped", "optional-group", "conditional", "group-exists", "fully-empty", "alternation", "named-group", "fullmatch", "pattern", "absent", "failure", "str", "gap"],
