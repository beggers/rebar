{
  "schema_version": 1,
  "manifest_id": "pattern-object-surface",
  "layer": "pattern_object_parity",
  "suite_id": "pattern.object",
  "defaults": {
    "flags": 0,
    "text_model": "str"
  },
  "cases": [
    {
      "id": "pattern-object-str-metadata",
      "operation": "pattern_metadata",
      "family": "compiled_pattern_metadata",
      "pattern": "abc",
      "categories": ["pattern", "metadata", "str"],
      "notes": [
        "Captures the first compiled str pattern object's visible type identity and scaffold attributes."
      ]
    },
    {
      "id": "pattern-object-str-ignorecase-metadata",
      "operation": "pattern_metadata",
      "family": "compiled_pattern_metadata",
      "pattern": "abc",
      "flags": 2,
      "categories": ["pattern", "metadata", "flags", "str"],
      "notes": [
        "Pins flag normalization on compiled str patterns alongside the scaffold type mismatch."
      ]
    },
    {
      "id": "pattern-object-bytes-ignorecase-metadata",
      "operation": "pattern_metadata",
      "family": "compiled_pattern_metadata",
      "pattern": "abc",
      "flags": 2,
      "text_model": "bytes",
      "categories": ["pattern", "metadata", "flags", "bytes"],
      "notes": [
        "Mirrors compiled-pattern metadata for bytes payloads without relying on str-only UNICODE behavior."
      ]
    },
    {
      "id": "pattern-search-literal-success",
      "operation": "pattern_call",
      "family": "compiled_pattern_literal_behavior",
      "pattern": "abc",
      "helper": "search",
      "args": ["zzabczz"],
      "categories": ["pattern", "literal", "search"],
      "notes": [
        "Captures a successful Pattern.search() result for the bounded literal-only slice."
      ]
    },
    {
      "id": "pattern-match-literal-success",
      "operation": "pattern_call",
      "family": "compiled_pattern_literal_behavior",
      "pattern": "abc",
      "helper": "match",
      "args": ["abc"],
      "categories": ["pattern", "literal", "match"],
      "notes": [
        "Pins the successful anchored literal Pattern.match() contract against stdlib."
      ]
    },
    {
      "id": "pattern-fullmatch-literal-success",
      "operation": "pattern_call",
      "family": "compiled_pattern_literal_behavior",
      "pattern": "abc",
      "helper": "fullmatch",
      "args": ["abc"],
      "categories": ["pattern", "literal", "fullmatch"],
      "notes": [
        "Captures the successful literal Pattern.fullmatch() contract."
      ]
    }
  ]
}
