      "pattern": "a(?P<word>b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abbbd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "named-group", "fullmatch", "pattern", "third-repetition", "bbb", "str", "gap"],
      "notes": [
        "Documents the named third-repetition success path on `abbbd` so the scorecard records the final named capture after the widest all-`b` selection allowed by `{1,3}`."
