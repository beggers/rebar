      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_named_pattern_third_repetition_bcc_workflow",
      "pattern": "a(?P<word>b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abccd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "named-group", "fullmatch", "pattern", "third-repetition", "bcc", "str", "gap"],
      "notes": [
        "Documents the named third-repetition success path on `abccd` so the broadened frontier includes one mixed branch order that ends on `c`."
      ]
    },
