{
  "schema_version": 1,
  "manifest_id": "quantified-alternation-broader-range-workflows",
  "layer": "match_behavior",
  "suite_id": "match.quantified_alternation_broader_range",
  "defaults": {
    "text_model": "str"
  },
  "cases": [
    {
      "id": "quantified-alternation-broader-range-numbered-compile-metadata-str",
      "operation": "compile",
      "family": "quantified_alternation_broader_range_numbered_compile_metadata",
      "pattern": "a(b|c){1,3}d",
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "compile", "metadata", "str", "gap"],
      "notes": [
        "Publishes the numbered compile frontier for one exact broader `{1,3}` quantified alternation without widening into open-ended repeats, nested alternation, conditionals, replacement workflows, or branch-local backreferences."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-module-search-lower-bound-b-str",
      "operation": "module_call",
      "family": "quantified_alternation_broader_range_numbered_module_lower_bound_b_workflow",
      "helper": "search",
      "args": ["a(b|c){1,3}d", "zzabdzz"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "search", "module", "lower-bound", "b-branch", "str", "gap"],
      "notes": [
        "Documents the numbered lower-bound module success path on `abd` so the wider counted range still records the final capture after one `b` repetition."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-module-search-lower-bound-c-str",
      "operation": "module_call",
      "family": "quantified_alternation_broader_range_numbered_module_lower_bound_c_workflow",
      "helper": "search",
      "args": ["a(b|c){1,3}d", "zzacdzz"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "search", "module", "lower-bound", "c-branch", "str", "gap"],
      "notes": [
        "Documents the numbered lower-bound module success path on `acd` so the scorecard keeps the alternate lower-bound branch explicit at the broader `{1,3}` frontier."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-pattern-fullmatch-third-repetition-bbb-str",
      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_numbered_pattern_third_repetition_bbb_workflow",
      "pattern": "a(b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abbbd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "fullmatch", "pattern", "third-repetition", "bbb", "str", "gap"],
      "notes": [
        "Documents the numbered third-repetition success path on `abbbd` so the scorecard records the final capture after the widest all-`b` branch selection allowed by `{1,3}`."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-pattern-fullmatch-third-repetition-bcc-str",
      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_numbered_pattern_third_repetition_bcc_workflow",
      "pattern": "a(b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abccd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "fullmatch", "pattern", "third-repetition", "bcc", "str", "gap"],
      "notes": [
        "Documents the numbered third-repetition success path on `abccd` so the broader range includes one mixed branch order that ends on `c`."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-pattern-fullmatch-third-repetition-bcb-str",
      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_numbered_pattern_third_repetition_bcb_workflow",
      "pattern": "a(b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abcbd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "fullmatch", "pattern", "third-repetition", "bcb", "str", "gap"],
      "notes": [
        "Documents the numbered third-repetition success path on `abcbd` so the scorecard keeps a mixed branch order that ends back on `b` explicit inside the exact `{1,3}` envelope."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-pattern-fullmatch-no-match-below-lower-bound-str",
      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_numbered_pattern_no_match_below_lower_bound_workflow",
      "pattern": "a(b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["ad"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "fullmatch", "pattern", "no-match", "below-lower-bound", "str", "gap"],
      "notes": [
        "Documents the numbered no-match path on `ad` so the scorecard stays explicit that widening to `{1,3}` does not erase the one-repetition lower bound."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-numbered-pattern-fullmatch-no-match-overflow-str",
      "operation": "pattern_call",
      "family": "quantified_alternation_broader_range_numbered_pattern_no_match_overflow_workflow",
      "pattern": "a(b|c){1,3}d",
      "helper": "fullmatch",
      "args": ["abbbcd"],
      "categories": ["grouped", "alternation", "quantifier", "bounded-repeat", "broader-range", "fullmatch", "pattern", "no-match", "overflow", "str", "gap"],
      "notes": [
        "Documents the numbered no-match path on `abbbcd` so the wider counted range still rejects a fourth alternation branch before the trailing literal `d`."
      ]
    },
    {
      "id": "quantified-alternation-broader-range-named-compile-metadata-str",
