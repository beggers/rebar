    1: from __future__ import annotations
       
    1: from collections import Counter
    1: from collections.abc import Iterable
    1: import importlib
    1: import json
    1: import pathlib
    1: import subprocess
    1: import sys
    1: import tempfile
    1: from types import ModuleType
    1: from typing import Any
       
       
    1: REPO_ROOT = pathlib.Path(__file__).resolve().parents[1]
    1: PYTHON_SOURCE = REPO_ROOT / "python"
       
    1: if str(PYTHON_SOURCE) not in sys.path:
    1:     sys.path.insert(0, str(PYTHON_SOURCE))
       
       
    1: def duplicate_items(counter: Counter[str]) -> list[str]:
           return sorted(item for item, count in counter.items() if count > 1)
       
       
    1: def duplicate_string_ids(items: Iterable[str]) -> tuple[str, ...]:
           return tuple(duplicate_items(Counter(items)))
       
       
    4: def declared_string_constants_by_suffix(
    1:     module: ModuleType,
           *,
    1:     name_suffix: str,
    1: ) -> dict[str, str]:
           return {
               name: value
               for name, value in vars(module).items()
               if name.endswith(name_suffix) and isinstance(value, str)
           }
       
       
    5: def run_harness_cli(
    1:     module_name: str,
    1:     cli_args: Iterable[str],
           *,
    2:     check: bool = True,
    1: ) -> subprocess.CompletedProcess[str]:
           command = [sys.executable, "-m", module_name, *cli_args]
           return subprocess.run(
               command,
               check=check,
               cwd=REPO_ROOT,
               env={"PYTHONPATH": str(PYTHON_SOURCE)},
               capture_output=True,
               text=True,
           )
       
       
    5: def run_harness_scorecard(
    1:     module_name: str,
    1:     cli_args: Iterable[str],
           *,
    1:     report_name: str,
    1: ) -> tuple[dict[str, Any], dict[str, Any]]:
           with tempfile.TemporaryDirectory() as temp_dir:
               report_path = pathlib.Path(temp_dir) / report_name
               result = run_harness_cli(
                   module_name,
                   [*cli_args, "--report", str(report_path)],
               )
               summary = json.loads(result.stdout.strip())
               if report_path.suffix == ".json":
                   scorecard = json.loads(report_path.read_text(encoding="utf-8"))
               else:
                   try:
                       module = importlib.import_module(module_name)
                       load_report = module.SCORECARD_REPORT.load
                   except (ImportError, AttributeError) as exc:
                       raise ValueError(
                           f"run_harness_scorecard cannot load a non-JSON report for {module_name!r}"
                       ) from exc
                   scorecard = load_report(report_path)
       
           return summary, scorecard
