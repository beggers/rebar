    1:     def pattern_payload(self) -> str | bytes:
               if self.pattern is None:
                   raise ValueError(f"case {self.case_id!r} is missing a pattern payload")
               if self.text_model == "str":
                   return self.pattern
               if self.text_model == "bytes":
