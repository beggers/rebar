    8: def finalize_observation(
           *,
    1:     adapter: str,
    1:     case: FixtureCase,
    1:     outcome: str,
    1:     warnings_payload: list[dict[str, str]],
    2:     result: dict[str, Any] | list[Any] | str | int | float | bool | None = None,
    2:     exception: dict[str, Any] | None = None,
    1: ) -> dict[str, Any]:
           return {
               "adapter": adapter,
               "operation": case.operation,
               "outcome": outcome,
               "warnings": warnings_payload,
               "result": result,
               "exception": exception,
