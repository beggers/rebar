{
  "runtime": {
    "artifact_dir": ".rebar/runtime",
    "sleep_seconds": 300,
    "failure_backoff_seconds": 30,
    "default_timeout_seconds": 1800
  },
  "agents": {
    "directory": "ops/agents"
  },
  "codex_defaults": {
    "bin": "codex",
    "codex_home": "~/.codex",
    "sandbox": "workspace-write",
    "ask_for_approval": "never",
    "common_config": [
      "suppress_unstable_features_warning=true"
    ],
    "extra_env": {
      "CODEX_NO_UPDATE": "1"
    }
  }
}
