{
  "schema_version": 1,
  "manifest_id": "literal-flag-boundary",
  "spec_refs": [
    "docs/benchmarks/plan.md",
    "docs/spec/drop-in-re-compatibility.md"
  ],
  "notes": [
    "Literal-flag boundary workloads keep patterns and haystacks intentionally tiny so the timings expose API-level IGNORECASE helper-call overhead instead of regex throughput.",
    "Supported literal-only IGNORECASE helpers are measured directly, while unsupported flag combinations stay in the same pack as explicit known-gap rows rather than disappearing from the scorecard."
  ],
  "defaults": {
    "warmup_iterations": 2,
    "sample_iterations": 5,
    "timed_samples": 7
  },
  "workloads": [
    {
      "id": "module-search-ignorecase-warm-str-hit",
      "bucket": "module-search",
      "family": "module",
      "operation": "module.search",
      "pattern": "AbC",
      "haystack": "zzaBczz",
      "flags": 2,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "smoke": true,
      "categories": [
        "flag",
        "ignorecase",
        "search",
        "literal",
        "warm-cache",
        "smoke"
      ],
      "syntax_features": [
        "module-search",
        "literal-text",
        "api-level-ignorecase"
      ],
      "notes": [
        "Warm module.search IGNORECASE helper path over a tiny str haystack with a single literal hit."
      ]
    },
    {
      "id": "module-search-ignorecase-purged-bytes-hit",
