{
  "schema_version": 1,
  "manifest_id": "exact-repeat-quantified-group-boundary",
  "spec_refs": [
    "docs/benchmarks/plan.md",
    "docs/spec/drop-in-re-compatibility.md"
  ],
  "notes": [
    "Exact-repeat quantified-group boundary workloads keep captures, counted repeats, and haystacks intentionally tiny so the scorecard measures helper-call overhead for the newly supported bounded exact-repeat slice rather than regex throughput.",
    "Measured rows cover the bounded `a(bc){2}d` and `a(?P<word>bc){2}d` compile/search/fullmatch paths directly, while ranged repeats and quantified-alternation combinations stay as explicit known-gap rows until the queued follow-on slices land."
  ],
  "defaults": {
    "warmup_iterations": 2,
    "sample_iterations": 5,
    "timed_samples": 7
  },
  "workloads": [
    {
      "id": "module-compile-numbered-exact-repeat-group-cold-str",
      "bucket": "module-compile",
      "family": "module",
      "operation": "module.compile",
      "pattern": "a(bc){2}d",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "cold",
      "timing_scope": "module-helper-call",
      "categories": [
        "compile",
        "grouped",
        "quantifier",
        "exact-repeat",
        "counted-repeat",
        "cold-cache"
      ],
      "syntax_features": [
        "module-compile",
        "grouping-forms",
        "quantifiers",
        "counted-repeats"
      ],
      "notes": [
        "Cold module.compile benchmark for the bounded numbered exact-repeat quantified-group slice so compile metadata timing reaches the published benchmark report."
      ]
    },
    {
      "id": "module-search-numbered-exact-repeat-group-warm-str",
      "bucket": "module-search",
      "family": "module",
      "operation": "module.search",
      "pattern": "a(bc){2}d",
      "haystack": "zzabcbcdzz",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "smoke": true,
      "categories": [
        "grouped",
        "quantifier",
        "exact-repeat",
        "counted-repeat",
        "search",
        "module",
        "warm-cache",
        "smoke"
      ],
      "syntax_features": [
        "module-search",
        "grouping-forms",
        "quantifiers",
        "counted-repeats"
      ],
      "notes": [
        "Warm module.search helper path for the bounded numbered exact-repeat workflow on a tiny haystack."
      ]
    },
    {
      "id": "pattern-fullmatch-numbered-exact-repeat-group-purged-str",
      "bucket": "pattern-fullmatch",
      "family": "module",
      "operation": "pattern.fullmatch",
      "pattern": "a(bc){2}d",
      "haystack": "abcbcd",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "purged",
      "timing_scope": "pattern-helper-call",
      "categories": [
        "pattern",
        "grouped",
        "quantifier",
        "exact-repeat",
        "counted-repeat",
        "fullmatch",
        "purged-cache"
      ],
      "syntax_features": [
        "pattern-fullmatch",
        "grouping-forms",
        "quantifiers",
        "counted-repeats",
        "cache-purge"
      ],
      "notes": [
        "Purged-cache Pattern.fullmatch probe for the same bounded numbered exact-repeat workflow."
      ]
    },
    {
      "id": "module-compile-named-exact-repeat-group-warm-str",
      "bucket": "module-compile",
      "family": "module",
      "operation": "module.compile",
      "pattern": "a(?P<word>bc){2}d",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "categories": [
        "compile",
        "grouped",
