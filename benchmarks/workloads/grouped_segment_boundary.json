{
  "schema_version": 1,
  "manifest_id": "grouped-segment-boundary",
  "spec_refs": [
    "docs/benchmarks/plan.md",
    "docs/spec/drop-in-re-compatibility.md"
  ],
  "notes": [
    "Grouped-segment boundary workloads keep prefixes, suffixes, captures, and haystacks intentionally tiny so the scorecard measures helper-call overhead for the newly supported literal-segment slice rather than regex throughput.",
    "Measured rows cover the bounded `a(b)c` and `a(?P<word>b)c` compile/search/fullmatch paths directly, while grouped-alternation shapes stay as explicit known-gap rows until the alternation follow-on lands."
  ],
  "defaults": {
    "warmup_iterations": 2,
    "sample_iterations": 5,
    "timed_samples": 7
  },
  "workloads": [
    {
      "id": "module-compile-grouped-segment-cold-str",
      "bucket": "module-compile",
      "family": "module",
      "operation": "module.compile",
      "pattern": "a(b)c",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "cold",
      "timing_scope": "module-helper-call",
      "categories": [
        "compile",
        "grouped",
        "segment",
        "cold-cache"
      ],
      "syntax_features": [
        "module-compile",
        "grouping-forms",
        "grouped-segments"
      ],
      "notes": [
        "Cold module.compile benchmark for the bounded grouped-segment literal slice so compile metadata timing reaches the published benchmark report."
      ]
    },
    {
      "id": "module-search-grouped-segment-warm-str",
      "bucket": "module-search",
      "family": "module",
      "operation": "module.search",
      "pattern": "a(b)c",
      "haystack": "zabcz",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "smoke": true,
      "categories": [
        "grouped",
        "segment",
        "search",
        "module",
        "warm-cache",
        "smoke"
      ],
      "syntax_features": [
        "module-search",
        "grouping-forms",
        "grouped-segments"
      ],
      "notes": [
        "Warm module.search helper path for the bounded grouped-segment workflow on a tiny haystack."
      ]
    },
    {
      "id": "pattern-fullmatch-grouped-segment-purged-str",
      "bucket": "pattern-fullmatch",
      "family": "module",
      "operation": "pattern.fullmatch",
      "pattern": "a(b)c",
      "haystack": "abc",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "purged",
      "timing_scope": "pattern-helper-call",
      "categories": [
        "pattern",
        "grouped",
        "segment",
        "fullmatch",
        "purged-cache"
      ],
      "syntax_features": [
        "pattern-fullmatch",
        "grouping-forms",
        "grouped-segments",
        "cache-purge"
      ],
      "notes": [
        "Purged-cache Pattern.fullmatch probe for the same bounded grouped-segment literal path."
      ]
    },
    {
      "id": "module-compile-named-grouped-segment-warm-str",
      "bucket": "module-compile",
      "family": "module",
      "operation": "module.compile",
      "pattern": "a(?P<word>b)c",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "categories": [
        "compile",
        "grouped",
        "segment",
        "named-group",
        "warm-cache"
      ],
      "syntax_features": [
        "module-compile",
        "grouping-forms",
        "grouped-segments",
        "named-groups"
      ],
      "notes": [
        "Warm module.compile path for the bounded named grouped-segment literal slice so named metadata timing reaches the benchmark report."
      ]
    },
    {
      "id": "module-search-named-grouped-segment-warm-str",
      "bucket": "module-search",
      "family": "module",
      "operation": "module.search",
      "pattern": "a(?P<word>b)c",
      "haystack": "zabcz",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "warm",
      "timing_scope": "module-helper-call",
      "categories": [
        "grouped",
        "segment",
        "named-group",
        "search",
        "module",
        "warm-cache"
      ],
      "syntax_features": [
        "module-search",
        "grouping-forms",
        "grouped-segments",
        "named-groups"
      ],
      "notes": [
        "Warm module.search helper path for a tiny named grouped-segment capture so named runtime workflows produce real timings."
      ]
    },
    {
      "id": "pattern-fullmatch-named-grouped-segment-purged-str",
      "bucket": "pattern-fullmatch",
      "family": "module",
      "operation": "pattern.fullmatch",
      "pattern": "a(?P<word>b)c",
      "haystack": "abc",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "purged",
      "timing_scope": "pattern-helper-call",
      "smoke": true,
      "categories": [
        "pattern",
        "grouped",
        "segment",
        "named-group",
        "fullmatch",
        "purged-cache",
        "smoke"
      ],
      "syntax_features": [
        "pattern-fullmatch",
        "grouping-forms",
        "grouped-segments",
        "named-groups",
        "cache-purge"
      ],
      "notes": [
        "Smoke-sized Pattern.fullmatch probe for the bounded named grouped-segment workflow with compile cost kept outside the timed loop."
      ]
    },
    {
      "id": "module-search-grouped-alternation-cold-gap",
      "bucket": "module-search",
      "family": "module",
      "operation": "module.search",
      "pattern": "a(b|c)d",
      "haystack": "zabdz",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "cold",
      "timing_scope": "module-helper-call",
      "categories": [
        "grouped",
        "segment",
        "alternation",
        "search",
        "module",
        "cold-cache",
        "gap"
      ],
      "syntax_features": [
        "module-search",
        "grouping-forms",
        "grouped-segments",
        "alternation"
      ],
      "notes": [
        "Explicit grouped-alternation gap row so tiny branch selection inside a group stays visible while alternation work is still queued."
      ]
    },
    {
      "id": "pattern-fullmatch-named-grouped-alternation-purged-gap",
      "bucket": "pattern-fullmatch",
      "family": "module",
      "operation": "pattern.fullmatch",
      "pattern": "a(?P<word>b|c)d",
      "haystack": "abd",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "purged",
      "timing_scope": "pattern-helper-call",
      "categories": [
        "pattern",
        "grouped",
        "segment",
        "alternation",
        "named-group",
        "fullmatch",
        "purged-cache",
        "gap"
      ],
      "syntax_features": [
        "pattern-fullmatch",
        "grouping-forms",
        "grouped-segments",
        "named-groups",
        "alternation",
        "cache-purge"
      ],
      "notes": [
        "Matching named grouped-alternation gap row that keeps the next grouped branch-selection frontier on the benchmark surface."
      ]
    }
  ]
}
