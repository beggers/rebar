{
  "schema_version": 1,
  "manifest_id": "open-ended-quantified-group-boundary",
  "spec_refs": [
    "docs/benchmarks/plan.md",
    "docs/spec/drop-in-re-compatibility.md"
  ],
  "notes": [
    "Open-ended quantified-group boundary workloads keep captures, one grouped `bc|de` alternation site, and haystacks intentionally tiny so the scorecard measures helper-call overhead for the newly supported bounded `{1,}` slice rather than regex throughput.",
    "Measured rows cover the bounded `a(bc|de){1,}d` and `a(?P<word>bc|de){1,}d` compile/search/fullmatch paths directly at representative lower-bound, mixed-branch, and fourth-repetition haystacks, and retain one carried-forward bounded grouped-conditional anchor `a((bc|de){1,3})?(?(1)d|e)` as a measured comparison row, while broader counted-repeat grouped families and broader grouped backtracking-heavy shapes stay as explicit known-gap rows until queued follow-on slices land."
  ],
  "defaults": {
    "warmup_iterations": 2,
    "sample_iterations": 5,
    "timed_samples": 7
  },
  "workloads": [
    {
      "id": "module-compile-numbered-open-ended-group-alternation-cold-str",
      "bucket": "module-compile",
      "family": "module",
      "operation": "module.compile",
      "pattern": "a(bc|de){1,}d",
      "flags": 0,
      "text_model": "str",
      "cache_mode": "cold",
      "timing_scope": "module-helper-call",
      "categories": [
        "compile",
        "grouped",
        "alternation",
        "quantifier",
        "counted-repeat",
        "open-ended-repeat",
        "cold-cache"
