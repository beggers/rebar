      ]
    },
    {
      "id": "pattern-fullmatch-named-nested-group-branch-local-backreference-purged-gap",
      "bucket": "pattern-fullmatch",
      "family": "module",
      "operation": "pattern.fullmatch",
      "pattern": "a(?P<outer>(?P<inner>b|c))(?P=inner)d",
